# Copy to .env and fill in. Never commit the real .env.

# --- Teleport cluster ---
PROXY_ADDR=presales.teleportdemo.com:443

# Pin to (or near) the cluster's Teleport version. Plugins should not be
# newer than the Auth Service they talk to.
EVENT_HANDLER_VERSION=18.6.4
TBOT_VERSION=18.6.4

# Join token value for tbot, from `terraform output -raw join_token` in
# terraform/ after bootstrapping the bot (see tbot/README.md). Single-use —
# tbot only needs it for the initial join, then renews on its own.
BOT_JOIN_TOKEN=

# --- Postgres ---
POSTGRES_USER=audit
POSTGRES_PASSWORD=change-me
POSTGRES_DB=audit
# Used by audit-sink (in-container) and audit-report (from the host, via the
# published port).
DATABASE_URL_INTERNAL=postgres://audit:change-me@postgres:5432/audit
DATABASE_URL=postgres://audit:change-me@localhost:5432/audit
